# Copy to .env and adjust. The Phase-3 token is a SECRET: .env is gitignored, keep it so.

# The secha-metadata checkout (the rulebook the engine interprets)
SECHA_METADATA_ROOT=../secha-metadata

# The raw landing zone produced by secha-ingestion (Bronze)
SECHA_LANDING_ROOT=../secha-ingestion/data/landing

# Where Phase-1 canonical parquet is written (also the staging format for Phase 3)
SECHA_CANONICAL_ROOT=data/canonical

# --- Phase 3: Delta / Unity Catalog via Spark Connect (TUNI VPN required) ---
# Install the extra first: pip install -e ".[spark]"  (pyspark-client pinned to the server)
SECHA_SPARK_URL=sc://130.230.115.138:15772
SECHA_CATALOG_URL=http://130.230.115.140:8080
# UC token (secret). While the platform Keycloak flow is broken, this is the admin token
# from the UC server; see scripts/phase3/README.md section C.
SECHA_CATALOG_TOKEN=
# Cluster-visible staging path the Spark workers read canonical parquet from
SECHA_STAGING_ROOT=/net/nfs/data/secha/canonical-staging
