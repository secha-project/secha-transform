# Phase-3 handshake configuration. Copy to .env and fill in.
# .env is gitignored; NONE of these values may ever be committed.
# Sources for the values: data-platform-documentation (servers.md) and README.md here.

# --- Spark Connect + Unity Catalog (required) ---
SECHA_SPARK_URL=sc://130.230.115.138:15772
SECHA_CATALOG_URL=http://130.230.115.140:8080
# While Keycloak is broken: the admin token from the UC server (README.md section C).
# Once fixed: SECHA_CATALOG_TOKEN can be produced by get_uc_token.py instead.
SECHA_CATALOG_TOKEN=
SECHA_CATALOG_NAME=secha

# --- NFS staging (optional for the handshake; required for Step 3) ---
SECHA_STAGING_ROOT=/net/nfs/data/secha/canonical-staging

